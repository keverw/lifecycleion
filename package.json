  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "bun run update-docs && tsup",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "bun run lint && bun run type-check && bun run build && bun test",
    "dev": "tsup --watch",
    "test": "bun run scripts/check-playwright.ts && bun test",
    "playwright:install": "bunx playwright install chromium",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:docs": "prettier --write README.md \"docs/**/*.md\"",
    "update-docs": "markdown-toc-gen update README.md && bun run scripts/update-readme-version.ts && markdown-toc-gen update changelog.md && find docs -type f -name '*.md' -print0 | xargs -0 -n1 markdown-toc-gen update && bun run format:docs"
  },
  "keywords": [
    "lifecycle",
    "lifecycle-manager",
    "logger",
    "logging",
    "retry",
    "utilities",
    "typescript",
    "event-emitter",
    "process-signals",
    "graceful-shutdown",
    "application-lifecycle",
    "helpers",
    "utils",
    "async",
    "promises"
  ],
  "author": "Kevin Whitman (https://github.com/keverw)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/keverw/lifecycleion"
  },
