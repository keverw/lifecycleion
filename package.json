    "eslint-plugin-unicorn": "^62.0.0",
    "markdown-toc-gen": "^1.2.0",
    "prettier": "^3.6.2",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3"
  },
